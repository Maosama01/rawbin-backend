# ─── Rawbin Backend — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in real values before running docker compose.
# DO NOT commit .env to source control.

# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=development            # development | staging | production
DEBUG=true
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_USER=rawbin
POSTGRES_PASSWORD=rawbin_dev_secret
POSTGRES_DB=rawbin
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Constructed by config.py — override if needed
# DATABASE_URL=postgresql+asyncpg://rawbin:rawbin_dev_secret@db:5432/rawbin

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=rawbin_redis_dev
REDIS_DB=0

# ── Celery ─────────────────────────────────────────────────────────────────────
# Broker + backend are built from REDIS_* above; override if needed
# CELERY_BROKER_URL=redis://:rawbin_redis_dev@redis:6379/1
# CELERY_RESULT_BACKEND=redis://:rawbin_redis_dev@redis:6379/2

# ── Flower ─────────────────────────────────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=admin

# ── Device Pairing ─────────────────────────────────────────────────────────────
PAIRING_CHALLENGE_TTL_SECONDS=120   # How long a challenge nonce is valid

# Fernet key for device secret encryption (AES-128-CBC + HMAC-SHA256 envelope).
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# In production: load from AWS Secrets Manager / KMS envelope encryption.
# Leave blank in development — a dev key is derived from SECRET_KEY automatically.
DEVICE_SECRET_KEY=
